---
interface Destination {
  image: string;
  alt: string;
  title: string;
  description: string;
}

interface Props {
  destinations: Destination[];
}

const { destinations } = Astro.props;
---

<section class="container py-5 text-center">

  <div class="row g-4 justify-content-center">
    {destinations.map((destination) => (
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card destination-card border-0 shadow-sm h-100 text-start">
          <img
            src={destination.image}
            class="card-img-top"
            alt={destination.alt}
          />
          <div class="card-body">
            <h5 class="mb-2">{destination.title}</h5>
            <p class="text-muted small mb-0">{destination.description}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>