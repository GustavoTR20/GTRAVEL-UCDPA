---
const { currentPage = "home" } = Astro.props;
---

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-2 fixed-top rounded-4 mx-auto mt-3 px-3" style="max-width: 1100px;">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center" href="/">
      <img src="/images/lg GT.png" alt="GusTrip" class="nav-logo-lg">
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNavbar"
      aria-controls="mainNavbar"
      aria-expanded="false"
      aria-label="Toggle navigation" 
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-4">
        <li class="nav-item">
          <a class={`nav-link nav-link-lite ${currentPage === "home" ? "active" : ""}`} href="/">
            Home
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link nav-link-lite" href="/#landingPage">
            Destinations
          </a>
        </li>

        <li class="nav-item ms-lg-2">
          <a class="btn btn-dark btn-sm px-3 py-2 rounded-pill fw-semibold" href="/#landingPage">
            Get Started
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>