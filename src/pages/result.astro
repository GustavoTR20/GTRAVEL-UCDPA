---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<MainLayout title="GTRAVEL">
  <div class="bg-white results-page">
    <Navbar currentPage="results" />

    <main class="container py-5">
      <section id="resultsPage" class="mt-5 results-v2">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
          <div>
            <h2 class="results-title mb-1">Your Trip Plan</h2>
            <p class="results-subtitle mb-0">Weather overview, weekly forecast and travel suggestions.</p>
          </div>

          <button id="backBtn" type="button" class="btn btn-outline-dark rounded-pill px-3">
            ← Back
          </button>
        </div>

        <div class="card border-0 shadow-sm mb-4 rounded-4">
          <div class="card-body p-4 p-lg-5">
            <div class="text-uppercase small text-muted mb-2" style="letter-spacing:.12em;">
              TODAY'S WEATHER
            </div>

            <h3 id="resultCityTitle" class="results-city-title mb-2">—</h3>
            <div id="weatherSummary" class="results-city-meta">—</div>

            <p class="small text-muted mt-3 mb-0">*Forecast is an estimate based on the data source.</p>
          </div>
        </div>

        <div class="row g-4 mb-4">
          <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
              <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                  <h3 class="h5 mb-0">7-Day Forecast</h3>
                  <span class="small text-muted">Next days</span>
                </div>

                <div id="forecastGrid" class="forecast-grid"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
              <div class="card-body p-4">
                <h3 class="h5 mb-3">Travel Recommendations</h3>
                <ul id="recommendationsList" class="list-group"></ul>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
              <div class="card-body p-4">
                <h3 class="h5 mb-3">Planning Tips</h3>
                <ul id="tipsList" class="list-group"></ul>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <script is:inline src="/js/data.js"></script>
    <script is:inline src="/js/result.js"></script>
  </div>
</MainLayout>