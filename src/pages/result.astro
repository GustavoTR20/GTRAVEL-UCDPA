<!doctype html> 
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>GTRAVEL</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="src/css/style.css">
</head>

<body class="bg-white results-page">
  <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-2 fixed-top rounded-4 mx-auto mt-3 px-3" style="max-width: 1100px;">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center" href="index.html">
        <img src="public/images/lg GT.png" alt="GusTrip" class="nav-logo-lg">
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-4">
          <li class="nav-item">
            <a class="nav-link nav-link-lite" href="index.html">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link nav-link-lite" href="index.html#landingPage">Destinations</a>
          </li>
          <li class="nav-item ms-lg-2">
            <a class="btn btn-dark btn-sm px-3 py-2 rounded-pill fw-semibold" href="index.html#landingPage"> Get Started </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <section id="resultsPage" class="mt-5 results-v2">
      <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
        <div>
          <h2 class="results-title mb-1">Your Trip Plan</h2>
          <p class="results-subtitle mb-0"> Weather overview, weekly forecast and travel suggestions.</p>
        </div>

        <button id="backBtn" type="button" class="btn btn-outline-dark rounded-pill px-3">
          ← Back
        </button>
      </div>

      <div class="card border-0 shadow-sm mb-4 rounded-4">
        <div class="card-body p-4 p-lg-5">
          <div class="text-uppercase small text-muted mb-2" style="letter-spacing:.12em;">
            TODAY'S WEATHER
          </div>

          <h3 id="resultCityTitle" class="results-city-title mb-2">—</h3>
          <div id="weatherSummary" class="results-city-meta">—</div>

          <p class="small text-muted mt-3 mb-0"> *Forecast is an estimate based on the data source.</p>
        </div>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-12">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <div class="d-flex align-items-center justify-content-between mb-4">
                <h3 class="h5 mb-0">7-Day Forecast</h3>
                <span class="small text-muted">Next days</span>
              </div>

              <div id="forecastGrid" class="forecast-grid"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-12 col-lg-6">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
              <h3 class="h5 mb-3">Travel Recommendations</h3>
              <ul id="recommendationsList" class="list-group"></ul>
            </div>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
              <h3 class="h5 mb-3">Planning Tips</h3>
              <ul id="tipsList" class="list-group"></ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>© 2026 GusTrip</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="public/js/data.js" defer></script>
  <script src="public/js/result.js" defer></script>
</body>

</html>