---
import "../css/style.css";
---

<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>GTRAVEL</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="src/css/style.css">
</head>

<body class="bg-white">
  <header class="hero-v3 position-relative overflow-hidden text-dark">
    <div class="hero-v3-bg position-absolute top-0 start-0 w-100 h-100"></div>
    <div class="hero-v3-overlay position-absolute top-0 start-0 w-100 h-100"></div>

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-2 fixed-top rounded-4 mx-auto mt-3 px-3" style="max-width: 1100px;">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="index.html">
          <img src="public/images/lg GT.png" alt="GusTrip" class="nav-logo-lg">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-4">
            <li class="nav-item">
              <a class="nav-link nav-link-lite active" href="index.html">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link nav-link-lite" href="#landingPage">Destinations</a>
            </li>
            <li class="nav-item ms-lg-2">
              <a class="btn btn-dark btn-sm px-3 py-2 rounded-pill fw-semibold" href="#landingPage"> Get Started </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container position-relative z-3 hero-layout">
      <div class="row align-items-center">
        <div class="col-lg-6">
          <div class="hero-content">
            <h1 class="hero-title">GTRAVEL</h1>
            <p class="hero-description">Plan your next adventure with real-time weather data and smart recommendations for every destination. </p>

            <a class="btn btn-dark btn-lg rounded-pill px-4 fw-semibold hero-btn" href="#landingPage">  Start planning → </a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <main class="container py-5">
    <section id="topDestinations">
      <div class="text-center mb-5">
        <p class="text-uppercase small text-muted mb-2">Top selling</p>
        <h2 class="mb-0">Top Destinations</h2>
      </div>

      <div class="row g-4 justify-content-center">
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card destination-card border-0 shadow-sm h-100 text-start">
            <img src="public/images/coliseu4k.jpg" class="card-img-top" alt="Rome">
            <div class="card-body">
              <h5 class="mb-2">Rome, Italy</h5>
              <p class="text-muted small mb-0">Eternal city of art and history</p>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
          <div class="card destination-card border-0 shadow-sm h-100 text-start">
            <img src="public/images/london4k.jpg" class="card-img-top" alt="London">
            <div class="card-body">
              <h5 class="mb-2">London, United Kingdom</h5>
              <p class="text-muted small mb-0">Historic capital with modern flair</p>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
          <div class="card destination-card border-0 shadow-sm h-100 text-start">
            <img src="public/images/rj4k.jpg" class="card-img-top" alt="Rio de Janeiro">
            <div class="card-body">
              <h5 class="mb-2">Rio de Janeiro, Brazil</h5>
              <p class="text-muted small mb-0">Vibrant beaches and carnival spirit</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="landingPage" class="text-center">
      <h2 class="display-6 mb-4">Where do you want to go?</h2>

      <div id="searchBlock" class="mx-auto" style="max-width: 720px;">
        <div class="search-pill shadow-sm">
          <label class="visually-hidden" for="destinationSelect">Destination</label>

          <select id="destinationSelect" class="form-select search-select">
            <option value="">-- Select a city --</option>
          </select>

          <button id="planBtn" type="button" class="btn btn-primary search-btn"> Search </button>
        </div>

        <p id="status" role="status" aria-live="polite" class="small text-muted mt-2 mb-0"></p>
      </div>

      <p class="mt-4 text-muted">Your next adventure is waiting.</p>
    </section>

    <section id="testimonials">
      <div class="row align-items-center g-4">
        <div class="col-12 col-lg-5">
          <p class="text-uppercase small mb-2 testimonials-kicker">Feedback</p>
          <h2 class="display-5 mb-3">What People Say</h2>

          <div class="d-flex gap-2 mt-4">
            <button class="dot is-active" data-index="0" type="button" aria-label="Testimonial 1"></button>
            <button class="dot" data-index="1" type="button" aria-label="Testimonial 2"></button>
            <button class="dot" data-index="2" type="button" aria-label="Testimonial 3"></button>
          </div>
        </div>

        <div class="col-12 col-lg-7">
          <div class="testimonial-card shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
              <div></div>
              <div class="d-flex flex-column gap-2">
                <button class="arrow-btn" id="prevTestimonial" type="button" aria-label="Previous testimonial">▲</button>
                <button class="arrow-btn" id="nextTestimonial" type="button" aria-label="Next testimonial">▼</button>
              </div>
            </div>

            <blockquote id="testimonialText" class="mt-3 mb-4">
              "Lorem, ipsum dolor sit amet consectetur adipisicing elit. Dicta corporis consequuntur officiis beatae animi tenetur adipisci odio enim voluptatibus, impedit accusantium quas ab pariatur, illo nam libero eum nulla ad!"
            </blockquote>

            <div class="fw-semibold" id="testimonialName">Gustavo Taveira</div>
            <div class="text-muted small" id="testimonialLocation">Dublin, Ireland</div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>© 2026 GusTrip</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/data.js" defer></script>
  <script src="/js/script.js" defer></script>
</body>

</html>
